# ── Backend (set these on Render.com / Railway.app, or in server/.env for local dev) ──

# From https://developer.spotify.com/dashboard — create an app to get these
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Secret PIN the host enters to unlock host mode
HOST_PIN=1234

# Public URL of the deployed frontend (GitHub Pages), no trailing slash
FRONTEND_URL=https://[username].github.io/partyqueue

# Port for local development (Render/Railway set PORT automatically)
PORT=3001

# ── Frontend (build-time only — set as a GitHub Actions repository variable
#    named SERVER_URL, or in client/.env for local dev) ──

# Public URL of the deployed backend, no trailing slash
# VITE_SERVER_URL=https://partyqueue-server.onrender.com
